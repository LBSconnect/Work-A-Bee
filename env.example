# For LOCAL DEVELOPMENT ONLY. On Render, these are set in the dashboard
# (most are wired up automatically by render.yaml) - you don't need this
# file there. Copy this to ".env" only if you want to run the app on your
# own machine against a local/test Postgres database.

SECRET_KEY=change-this-to-a-random-string

# A Postgres connection string. Render's Blueprint sets this for you in
# production; for local dev you'd need your own Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/linton_timekeeping

# --- Microsoft 365 app registration (Graph API, sends mail via OAuth -
# not SMTP/basic auth) ---
MS_TENANT_ID=your-directory-tenant-id
MS_CLIENT_ID=your-app-registration-client-id
MS_CLIENT_SECRET=your-app-registration-client-secret
MS_SENDER_EMAIL=your-email@yourcompany.com
REPORT_RECIPIENT=info@lbsconnect.net

# --- Stripe (billing) ---
# Create the Starter ($0), Growth ($29/mo), and Business ($79/mo) recurring
# Prices in your Stripe Dashboard first, then paste their price IDs below.
# The webhook secret comes from the endpoint you register in Stripe pointing
# at https://<your-domain>/stripe/webhook.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_BUSINESS=price_...

# Default hourly rate pre-filled when adding a new employee (editable
# per-employee afterward).
DEFAULT_HOURLY_RATE=16.00

# The weekly report is sent Friday at this time (24h, Central time).
REPORT_HOUR=17
REPORT_MINUTE=0

# --- Notification emails (Postmark) ---
# A single platform-wide transactional email account, used for the in-app
# notification system (shift claimed, PTO decided, new message, recognition
# given). Unlike the MS Graph weekly report above, this is NOT per-customer -
# every org's notification emails go out through this one Postmark server
# token and From address. Get a server token from https://postmarkapp.com.
POSTMARK_SERVER_TOKEN=
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
